void setup() {
  pinMode(LED_BUILTIN, OUTPUT);
  pinMode(8, OUTPUT);
  pinMode(4, OUTPUT);
}

void loop() {
  digitalWrite(LED_BUILTIN, HIGH);
  digitalWrite(8, LOW);
  digitalWrite(4, LOW);
  delay(3000);   

  digitalWrite(LED_BUILTIN, LOW);    
  digitalWrite(8, HIGH);
  digitalWrite(4, LOW);
  delay(1500); 

  digitalWrite(LED_BUILTIN, LOW);    
  digitalWrite(8, LOW);
  digitalWrite(4, HIGH);
  delay(3000);                        
}
